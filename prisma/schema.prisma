// Tavok Database Schema
// All IDs are ULIDs (26-char, time-sortable, globally unique)
// Generated in application code, NOT by the database
//
// See docs/DECISIONS.md DEC-0004 for rationale on ULIDs
// See docs/PROTOCOL.md for cross-service contracts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH MODELS (NextAuth.js)
// ============================================================

model Account {
  id                String  @id @db.VarChar(26)
  userId            String  @db.VarChar(26)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @db.VarChar(26)
  sessionToken String   @unique
  userId       String   @db.VarChar(26)
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// CORE MODELS
// ============================================================

model User {
  id          String   @id @db.VarChar(26)
  email       String   @unique
  username    String   @unique
  displayName String
  avatarUrl   String?
  password    String // bcrypt hashed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  accounts       Account[]
  sessions       Session[]
  ownedServers   Server[]     @relation("ServerOwner")
  members        Member[]
  createdInvites Invite[]     @relation("InviteCreator")
  reactions      Reaction[]
  attachments    Attachment[]
  mentions       MessageMention[]
  readStates     ChannelReadState[]
  dmParticipants DmParticipant[]
  directMessages DirectMessage[]  @relation("DirectMessageAuthor")
}

model Server {
  id        String   @id @db.VarChar(26)
  name      String
  iconUrl   String?
  ownerId   String   @db.VarChar(26)

  // Agent registration settings (DEC-0047)
  allowAgentRegistration       Boolean @default(false) // whether external agents can self-register
  registrationApprovalRequired Boolean @default(true)  // require owner approval for self-registered agents

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  owner    User      @relation("ServerOwner", fields: [ownerId], references: [id])
  channels Channel[]
  members  Member[]
  invites  Invite[]
  roles    Role[]
  bots     Bot[]

  @@index([ownerId])
}

model Channel {
  id           String      @id @db.VarChar(26)
  serverId     String      @db.VarChar(26)
  name         String
  topic        String?
  type         ChannelType @default(TEXT)
  position     Int         @default(0)
  defaultBotId String?     @db.VarChar(26)
  lastSequence BigInt      @default(0) // tracks highest sequence for reconnection seed
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Swarm / Charter fields (TASK-0020, DEC-0050)
  swarmMode          SwarmMode      @default(HUMAN_IN_THE_LOOP)
  charterGoal        String?        @db.Text     // What agents should accomplish
  charterRules       String?        @db.Text     // Custom rules / instructions
  charterAgentOrder  String?        @db.Text     // JSON array of botIds for ordered modes
  charterMaxTurns    Int            @default(0)  // 0 = unlimited
  charterCurrentTurn Int            @default(0)  // Current turn counter
  charterStatus      CharterStatus  @default(INACTIVE)

  // Relations
  server           Server           @relation(fields: [serverId], references: [id], onDelete: Cascade)
  defaultBot       Bot?             @relation("ChannelDefaultBot", fields: [defaultBotId], references: [id], onDelete: SetNull)
  messages         Message[]
  channelBots      ChannelBot[]
  readStates       ChannelReadState[]
  inboundWebhooks  InboundWebhook[] // Discord-style incoming webhooks (DEC-0043)

  @@index([serverId, position])
}

model Message {
  id              String        @id @db.VarChar(26) // ULID: time-sortable
  channelId       String        @db.VarChar(26)
  authorId        String        @db.VarChar(26) // User.id or Bot.id
  authorType      AuthorType    @default(USER)
  content         String        @db.Text
  type            MessageType   @default(STANDARD)
  streamingStatus StreamStatus?
  sequence        BigInt // per-channel sequence number (assigned via Redis INCR)
  metadata        Json?         // Agent execution metadata: {model, provider, tokensIn, tokensOut, latencyMs, ...} (TASK-0039)
  thinkingTimeline String?       @db.Text // JSON array of {phase, timestamp} for thinking timeline replay (TASK-0011)
  editedAt        DateTime?                // null if never edited (TASK-0014)
  isDeleted       Boolean       @default(false)  // soft delete (TASK-0014)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  channel     Channel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  reactions   Reaction[]
  attachments Attachment[]
  mentions    MessageMention[]

  // Primary query path: messages in a channel, sorted by time (ULID is time-sorted)
  @@index([channelId, id])
  // Reconnection sync: find messages after a given sequence number
  @@index([channelId, sequence])
}

model Reaction {
  id        String   @id @db.VarChar(26)
  messageId String   @db.VarChar(26)
  userId    String   @db.VarChar(26)
  emoji     String   @db.VarChar(32) // Unicode emoji or shortcode
  createdAt DateTime @default(now())

  // Relations
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  // @@index([messageId]) — removed: composite unique index on (messageId, userId, emoji)
  // already serves messageId lookups via its leading column (ISSUE-029)
}

model Attachment {
  id          String   @id @db.VarChar(26)
  messageId   String?  @db.VarChar(26) // null until message is sent
  userId      String   @db.VarChar(26)
  filename    String
  mimeType    String
  size        Int // bytes
  storagePath String // path on disk relative to uploads dir
  createdAt   DateTime @default(now())

  // Relations
  message Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([userId])
}

model Role {
  id          String   @id @db.VarChar(26)
  serverId    String   @db.VarChar(26)
  name        String
  color       String? // hex color code e.g. "#FF5733"
  permissions BigInt   @default(0) // bitfield
  position    Int      @default(0)
  createdAt   DateTime @default(now())

  // Relations
  server  Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  members Member[]

  @@index([serverId, position])
}

model Member {
  id       String   @id @db.VarChar(26)
  userId   String   @db.VarChar(26)
  serverId String   @db.VarChar(26)
  nickname String?
  joinedAt DateTime @default(now())

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  roles  Role[]

  @@unique([userId, serverId])
  @@index([serverId])
}

model Invite {
  id        String    @id @db.VarChar(26)
  serverId  String    @db.VarChar(26)
  creatorId String    @db.VarChar(26)
  code      String    @unique @db.VarChar(8)
  maxUses   Int?
  uses      Int       @default(0)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  // Relations
  server  Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  creator User   @relation("InviteCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([serverId])
  // @@index([code]) — removed: @unique on code already creates an index (ISSUE-029)
}

// ============================================================
// AI / BOT MODELS
// ============================================================

model Bot {
  id              String      @id @db.VarChar(26)
  name            String
  avatarUrl       String?
  serverId        String      @db.VarChar(26)
  llmProvider     String // "anthropic" | "openai" | "ollama" | "openrouter" | "custom"
  llmModel        String // "claude-sonnet-4-20250514" | "gpt-4" | "llama3" | etc.
  apiEndpoint     String // full URL to the API endpoint
  apiKeyEncrypted String      @db.Text // encrypted at rest in application layer
  systemPrompt    String      @db.Text
  temperature     Float       @default(0.7)
  maxTokens       Int         @default(4096)
  isActive        Boolean     @default(true)
  triggerMode     TriggerMode @default(MENTION)
  thinkingSteps    String?           @db.Text // JSON array of phase labels e.g. ["Planning","Researching","Drafting","Reviewing"]
  enabledTools     String?           @db.Text // JSON array of tool names e.g. ["current_time","web_search"] — null/empty = all tools (TASK-0018)
  connectionMethod ConnectionMethod? // null = BYOK (UI-configured), non-null = SDK/webhook/etc (DEC-0047)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Relations
  server            Server             @relation(fields: [serverId], references: [id], onDelete: Cascade)
  defaultChannels   Channel[]          @relation("ChannelDefaultBot")
  channelBots       ChannelBot[]
  agentRegistration AgentRegistration? // null for UI-configured bots (DEC-0040)
  inboundWebhooks   InboundWebhook[]   // Discord-style incoming webhooks (DEC-0043)

  @@index([serverId])
}

// Agent self-registration (DEC-0040)
// Agents that register themselves via API, not configured through the UI.
// Each AgentRegistration creates and owns a Bot record, so all existing
// streaming/channel/persistence logic works unchanged.
model AgentRegistration {
  id              String   @id @db.VarChar(26)
  botId           String   @unique @db.VarChar(26)
  apiKeyHash      String   @db.VarChar(64) // SHA-256 hex hash (high-entropy key, fast lookup)
  capabilities    Json     @default("[]") // ["text", "code", "web_search", "tool_use"]
  healthUrl       String?  // endpoint for health checks
  webhookUrl      String?  // endpoint for inbound events
  maxTokensSec    Int      @default(100) // rate limit: tokens per second
  lastHealthCheck DateTime?
  lastHealthOk    Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Universal agent connectivity (DEC-0043)
  connectionMethod   ConnectionMethod @default(WEBSOCKET)
  webhookSecret      String?  @db.VarChar(64)  // HMAC-SHA256 signing secret for outbound webhook payloads
  webhookTimeout     Int      @default(30000)   // ms timeout for webhook HTTP responses
  inboundWebhookToken String? @db.VarChar(64)  // separate URL-safe token for simple webhook auth
  sseEnabled         Boolean  @default(false)   // whether SSE event endpoint is active for this agent
  openaiSystemPrompt String?  @db.Text          // override system prompt for OpenAI-compat mode

  // Approval flow (DEC-0047)
  approvalStatus ApprovalStatus @default(APPROVED) // APPROVED default = backward compat for existing agents
  reviewedBy     String?        @db.VarChar(26)    // userId of who approved/rejected
  reviewedAt     DateTime?

  // Relation: each AgentRegistration owns exactly one Bot
  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  // Fast lookup by API key hash on every WebSocket connect
  @@index([apiKeyHash])
}

// Multi-bot channel assignment (TASK-0012, DEC-0038)
// Replaces the single defaultBotId for multi-stream support.
// defaultBotId is kept on Channel for backward compatibility.
model ChannelBot {
  id        String   @id @db.VarChar(26)
  channelId String   @db.VarChar(26)
  botId     String   @db.VarChar(26)
  createdAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  bot     Bot     @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([channelId, botId])
  @@index([channelId])
}

// Discord-style incoming webhooks (DEC-0045)
// One URL per channel, token embedded in URL. No headers needed.
// Any system (curl, CI/CD, n8n) can POST a message by hitting the URL.
model InboundWebhook {
  id        String   @id @db.VarChar(26)
  channelId String   @db.VarChar(26)
  botId     String   @db.VarChar(26)
  token     String   @unique @db.VarChar(64) // whk_... token — the URL IS the auth
  name      String                           // display name for messages sent through this webhook
  avatarUrl String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  bot     Bot     @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([channelId])
}

// Agent message queue for REST polling (DEC-0043)
// When a message triggers a REST_POLL or WEBHOOK bot, a row is inserted here.
// The agent picks it up on next poll. Ephemeral — auto-cleanup after 24h.
model AgentMessage {
  id         String   @id @db.VarChar(26)
  botId      String   @db.VarChar(26)
  channelId  String   @db.VarChar(26)
  messageId  String   @db.VarChar(26) // reference to the original Message
  content    String   @db.Text
  authorId   String   @db.VarChar(26)
  authorName String
  authorType String   // "USER" | "BOT"
  delivered  Boolean  @default(false)
  expiresAt  DateTime // TTL — auto-cleanup after 24h
  createdAt  DateTime @default(now())

  // Primary polling query: undelivered messages for a bot, ordered by time
  @@index([botId, delivered, createdAt])
  @@index([botId, channelId])
}

// Mention persistence (TASK-0015)
// Tracks which users are mentioned in each message.
// Used by TASK-0016 (unread mention counting) and TASK-0029 (notifications).
model MessageMention {
  id        String @id @db.VarChar(26)
  messageId String @db.VarChar(26)
  userId    String @db.VarChar(26)

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

// Per-user per-channel read state (TASK-0016)
// Tracks what each user has read. Used for unread indicators and mention badges.
model ChannelReadState {
  id           String   @id @db.VarChar(26)
  userId       String   @db.VarChar(26)
  channelId    String   @db.VarChar(26)
  lastReadSeq  BigInt   @default(0)
  mentionCount Int      @default(0)
  updatedAt    DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([userId])
}

// ============================================================
// DIRECT MESSAGES (TASK-0019)
// ============================================================

// DM channel — a private conversation between two users.
// Lives outside the server hierarchy. No serverId, no bots.
model DirectMessageChannel {
  id        String   @id @db.VarChar(26)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants DmParticipant[]
  messages     DirectMessage[]
}

// DM participant — tracks who is in a DM conversation.
// Enables future multi-user DMs (group DMs) without schema changes.
model DmParticipant {
  id     String @id @db.VarChar(26)
  dmId   String @db.VarChar(26)
  userId String @db.VarChar(26)

  dm   DirectMessageChannel @relation(fields: [dmId], references: [id], onDelete: Cascade)
  user User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dmId, userId])
  @@index([userId])
}

// Direct message — a message within a DM channel.
// Mirrors Message model structure but scoped to DMs, not server channels.
model DirectMessage {
  id        String    @id @db.VarChar(26)
  dmId      String    @db.VarChar(26)
  authorId  String    @db.VarChar(26)
  content   String    @db.Text
  editedAt  DateTime?
  isDeleted Boolean   @default(false)
  sequence  BigInt
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  dm     DirectMessageChannel @relation(fields: [dmId], references: [id], onDelete: Cascade)
  author User                 @relation("DirectMessageAuthor", fields: [authorId], references: [id])

  @@index([dmId, sequence])
  @@index([dmId, id])
}

// ============================================================
// ENUMS
// ============================================================

enum ChannelType {
  TEXT
  ANNOUNCEMENT
}

enum MessageType {
  STANDARD
  STREAMING
  SYSTEM
  TOOL_CALL    // Agent tool invocation — content is JSON: {callId, toolName, arguments, status} (TASK-0039)
  TOOL_RESULT  // Agent tool result — content is JSON: {callId, result, error, durationMs} (TASK-0039)
  CODE_BLOCK   // Agent code output — content is JSON: {language, code, filename?} (TASK-0039)
  ARTIFACT     // Agent artifact — content is JSON: {artifactType, title, content} (TASK-0039)
  STATUS       // Agent status update — content is JSON: {state, detail} (TASK-0039)
}

enum StreamStatus {
  ACTIVE
  COMPLETE
  ERROR
}

enum AuthorType {
  USER
  BOT
  SYSTEM
}

enum TriggerMode {
  ALWAYS
  MENTION
  KEYWORD
}

// Agent registration approval status (DEC-0047)
enum ApprovalStatus {
  PENDING   // Awaiting server owner approval
  APPROVED  // Approved and active
  REJECTED  // Rejected by server owner
}

// Agent connection method — how an agent communicates with Tavok (DEC-0043)
enum ConnectionMethod {
  WEBSOCKET       // Existing: Phoenix Channel V2 (Python SDK, TS SDK)
  WEBHOOK         // Tavok calls agent's URL on trigger (Slack/Telegram pattern)
  INBOUND_WEBHOOK // Agent POSTs into Tavok (Discord incoming webhooks pattern)
  REST_POLL       // Agent polls for messages (serverless/Lambda pattern)
  SSE             // Agent receives events via SSE, sends via REST
  OPENAI_COMPAT   // Agent speaks OpenAI Chat Completions format
}

// Swarm collaboration mode — how agents interact in a channel (TASK-0020, DEC-0050)
enum SwarmMode {
  HUMAN_IN_THE_LOOP   // Default — agents only respond when mentioned/triggered
  LEAD_AGENT          // One agent leads, others assist when asked
  ROUND_ROBIN         // Agents take turns in defined order
  STRUCTURED_DEBATE   // Agents present opposing viewpoints
  CODE_REVIEW_SPRINT  // Sequential review pattern
  FREEFORM            // Any agent can respond anytime
  CUSTOM              // User-defined rules via charter text
}

// Charter session status (TASK-0020)
enum CharterStatus {
  INACTIVE   // No active swarm session
  ACTIVE     // Swarm is running
  PAUSED     // Paused by human override
  COMPLETED  // Max turns reached or /end issued
}
